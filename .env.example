# =============================================================================
# telemon — configuration template
# Copy this file to .env and fill in your values
# =============================================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890

# --- Timing ---
CHECK_INTERVAL=10        # seconds between monitoring cycles
ALERT_COOLDOWN=300       # seconds before the same alert can repeat (5 min)

# --- Thresholds ---
DISK_THRESHOLD_GB=50         # alert when free space on / drops below this
MEMORY_THRESHOLD_PCT=90      # alert when RAM usage exceeds this %
CPU_THRESHOLD_PCT=95         # alert when CPU usage exceeds this %
SWAP_THRESHOLD_PCT=80        # alert when swap usage exceeds this %
LOAD_THRESHOLD=10.0          # alert when 1-min load average exceeds this

DISK_IO_READ_MBPS=200        # alert when sustained read throughput exceeds this MB/s
DISK_IO_WRITE_MBPS=100       # alert when sustained write throughput exceeds this MB/s

# --- Service watchdog (systemd units, comma-separated) ---
WATCHED_SERVICES=nginx,postgresql

# --- Docker container watchdog (container names, comma-separated) ---
# Use the exact names shown by: docker ps --format '{{.Names}}'
WATCHED_CONTAINERS=nginx-prod,postgres-db,redis-cache

# --- PM2 process watchdog ---
# User whose PM2 daemon to query
PM2_USER=localdevs
# PM2 process names to watch (from: pm2 status)
WATCHED_PM2=web_api,cron_service

# --- Journal error filters ---
# Systemd units to ignore entirely (comma-separated)
IGNORED_UNITS=ssh.service,sshd.service

# Suppress errors whose message contains any of these substrings (case-insensitive)
# To disable all filtering set: IGNORED_PATTERNS=
IGNORED_PATTERNS=kex_exchange_identification,Connection reset by peer,Disconnected from invalid user,Disconnected from authenticating user,Invalid user,Failed password,Did not receive identification string,banner exchange: Connection from
